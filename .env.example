# Copy to backend/.env for local (non-Docker) development.
# Not used by docker-compose.yml, which sets these directly as container env vars.

DATABASE_URL=sqlite+aiosqlite:///./data/savr.db

# Leave MASTER_KEY unset to auto-generate and persist a key at MASTER_KEY_FILE
# on first run. Set MASTER_KEY explicitly (e.g. in tests/CI) to skip that.
MASTER_KEY_FILE=./data/master.key
# MASTER_KEY=

# AI copilot (Part 2). Provider-agnostic by design; "ollama" is the only one
# implemented so far. Point OLLAMA_BASE_URL at wherever `ollama serve` is
# running (defaults assume it's on the same machine as the backend).
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
# OLLAMA_REQUEST_TIMEOUT_S=120

# Safety: appended to (never replaces) the built-in dangerous-command denylist
# in backend/app/ai/safety.py. Comma or newline separated regex patterns.
# AI_DANGEROUS_EXTRA_PATTERNS=

# Tuning (sane defaults, rarely need changing):
# AI_SCROLLBACK_MAX_BYTES=65536
# AI_COMMAND_QUIET_MS=700
# AI_COMMAND_MAX_WAIT_MS=5000
# AI_MAX_HISTORY_MESSAGES=40
# Caps a single model turn's generated length (Ollama's `num_predict`), so a
# model that degenerates into a repetition loop stalls for one bounded
# generation instead of minutes. Raise it if a "thinking" model's responses
# get cut off before reaching its actual answer.
# AI_MAX_RESPONSE_TOKENS=1024
