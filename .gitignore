# Python
backend/.venv/
backend/.venv-desktop-build/
backend/__pycache__/
backend/**/__pycache__/
backend/*.egg-info/
backend/.pytest_cache/

# Local data (sqlite db, master key)
data/
backend/data/

# Node / frontend
frontend/node_modules/
frontend/dist/

# Frontend build copied in at Docker build time, not source
backend/app/static/

# PyInstaller desktop build output
backend/build/
backend/dist/

# Env files
.env
backend/.env

# Editor
.vscode/

# Local Claude Code settings (per-developer, not shared)
.claude/settings.local.json

# LoRA fine-tuning workspace: scripts/schema are tracked, everything else
# (model weights, checkpoints, venv, and raw captures that may contain real
# device hostnames/IPs/secrets) is not.
training/.venv/
training/models/
training/checkpoints/
training/dataset/raw/
training/dataset/*.jsonl
!training/dataset/example.jsonl

# Raw dataset drops outside training/ (same policy as above -- unverified
# training text, not project source) and Unsloth's local kernel compile cache
# (can appear at repo root or under training/scripts/ depending on cwd).
/dataset_savrV2/
unsloth_compiled_cache/
training/**/__pycache__/
